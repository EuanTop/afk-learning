{
  "name": "capybara-letter",
  "version": "0.1.0",
  "private": true,
  "description": "卡皮巴拉的来信 — bilingual educational product powered by OpenClaw",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @capybara-letter/frontend dev",
    "dev:frontend": "pnpm --filter @capybara-letter/frontend dev",
    "openclaw:install": "openclaw plugins install ./plugin",
    "openclaw:install:copy": "openclaw plugins install ./plugin",
    "openclaw:install:link": "openclaw plugins install -l ./plugin",
    "seed:mock-session": "pnpm --filter @capybara-letter/plugin seed:mock-session",
    "build": "pnpm -r build",
    "check": "pnpm -r --parallel --if-present run typecheck"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0"
}
