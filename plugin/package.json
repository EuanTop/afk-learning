{
  "name": "@capybara-letter/plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Capybara's Letter — OpenClaw channel plugin",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed:mock-session": "pnpm dlx tsx ./scripts/seed-mock-session.ts"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.12"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41",
    "ts-fsrs": "^5.3.2",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/ws": "^8.18.1",
    "openclaw": ">=2026.4.12",
    "typescript": "^6.0.2"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "capybara-letter",
      "label": "Capybara's Letter",
      "selectionLabel": "Capybara's Letter (Education)",
      "detailLabel": "Capybara's Letter",
      "docsPath": "/channels/capybara-letter",
      "docsLabel": "capybara-letter",
      "blurb": "Bilingual educational channel: children make wishes, Capybara delivers letters.",
      "systemImage": "letter",
      "order": 900,
      "exposure": {
        "configured": true,
        "setup": true,
        "docs": false
      }
    },
    "install": {
      "npmSpec": "@capybara-letter/plugin",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.12"
    }
  }
}
