# Capybara Letter backend TTS
# Loaded automatically by @capybara-letter/plugin after OpenClaw Gateway starts.

CAPYBARA_TTS_XFYUN_APP_ID=your_app_id
CAPYBARA_TTS_XFYUN_API_KEY=your_api_key
CAPYBARA_TTS_XFYUN_API_SECRET=your_api_secret

# Optional voice tuning
CAPYBARA_TTS_XFYUN_VCN=x_lele
CAPYBARA_TTS_XFYUN_SPEED=45
CAPYBARA_TTS_XFYUN_VOLUME=65
CAPYBARA_TTS_XFYUN_PITCH=50
